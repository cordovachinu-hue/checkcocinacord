rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de evidencia: cualquier estación puede subir (máx 10MB,
    // solo imágenes), pero solo gerencia autenticada puede verlas.
    match /evidencias/{allPaths=**} {
      allow write: if request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow read: if true;
    }
  }
}
